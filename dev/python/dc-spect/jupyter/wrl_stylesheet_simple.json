      "enabled": true,
      "style": {
        "color": "pink",
        "opacity": 0.4,
        "edge_color": "red",
        "legend_name": "Optical Epoxy"
      }
    },
    {
      "pattern": "sipm:*",
      "enabled": true,
      "style": {
        "color": "green",
        "opacity": 0.2,
        "edge_color": "darkgreen",
        "legend_name": "sipm"
